# Supabase — modo banco (opcional)
# Sem estas variáveis, o app roda em modo demo (dados mock, nada é salvo).
# Com elas preenchidas, o app lê e grava no seu banco Supabase.
#
# Onde achar: Supabase → Project Settings → API
#  - VITE_SUPABASE_URL  = Project URL   (ex: https://xxxxxxxx.supabase.co)
#  - VITE_SUPABASE_ANON_KEY = a chave publishable / anon (NUNCA a service_role)

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
